{
  "name": "corefront-endconcepts",
  "version": "1.0.0",
  "type": "module",
  "lint-staged": {
    "*.{js,jsx,ts,tsx,vue}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{css,less,scss,md,json}": [
      "prettier --write"
    ]
  },
  "packageManager": "pnpm@11.2.2",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "monitor:lh": "unlighthouse-ci --site http://localhost:4173/CoreFront-EndConcepts/ --desktop",
    "type-check": "turbo run type-check",
    "type-check:tsconfig": "vue-tsc -b --noEmit",
    "docs:dev": "run-s xb:build docs:dev-only",
    "docs:dev-only": "vitepress dev apps/docs",
    "docs:build": "run-s xb:build docs:build-only",
    "docs:build-only": "cross-env NODE_OPTIONS=\\\"--max-old-space-size=8192\\\" vitepress build apps/docs",
    "docs:preview": "vitepress preview apps/docs",
    "docs:clean": "rm -rf apps/docs/.vitepress/.temp apps/docs/.vitepress/cache node_modules/.vite",
    "docs:rebuild": "pnpm run docs:clean && pnpm run docs:build",
    "xb:build": "pnpm --filter xb-element build",
    "xb:test": "vitest run packages/xbElement",
    "xb:release": "pnpm --filter xb-element release",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "run-s test:xb release:build changeset:publish",
    "release:build": "pnpm --filter packages/xbElement run build",
    "changeset:publish": "changeset publish",
    "preview": "vite preview",
    "test": "run-s test:vue test:xb",
    "test:vue": "vitest run packages/vue",
    "test:xb": "vitest run packages/xbElement",
    "prepare": "husky"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@floating-ui/vue": "^1.1.11",
    "@fortawesome/fontawesome-svg-core": "^7.1.0",
    "@fortawesome/free-solid-svg-icons": "^7.1.0",
    "@fortawesome/vue-fontawesome": "^3.1.2",
    "@rollup/plugin-alias": "^6.0.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@sentry/vite-plugin": "^5.3.0",
    "@sentry/vue": "^10.58.0",
    "@tsconfig/node24": "^24.0.3",
    "@types/jsdom": "^27.0.0",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^24.10.1",
    "@unlighthouse/cli": "^0.17.10",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vitejs/plugin-vue-jsx": "^5.1.2",
    "@vitepress-demo-preview/component": "^2.6.2",
    "@vitepress-demo-preview/plugin": "^1.4.1",
    "@vitest/eslint-plugin": "^1.5.0",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.6.0",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.8.1",
    "autoprefixer": "^10.4.23",
    "cross-env": "^10.1.0",
    "cssnano": "^7.1.2",
    "esbuild": "^0.28.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-vue": "~10.5.1",
    "happy-dom": "^20.0.11",
    "husky": "^9.1.7",
    "jiti": "^2.6.1",
    "jsdom": "^24.1.3",
    "lint-staged": "^17.0.0",
    "npm-run-all2": "^8.0.4",
    "postcss": "^8.5.6",
    "postcss-color-mix": "^1.1.0",
    "postcss-each": "^1.1.0",
    "postcss-each-variables": "^0.3.0",
    "postcss-for": "^2.1.1",
    "postcss-nested": "^7.0.2",
    "prettier": "^3.6.2",
    "rollup": "^4.60.1",
    "rollup-plugin-esbuild": "^6.2.1",
    "rollup-plugin-visualizer": "^7.0.1",
    "sharp": "^0.34.5",
    "svgo": "^4.0.1",
    "tslib": "^2.8.1",
    "turbo": "^2.9.16",
    "typescript": "~5.9.0",
    "unplugin-dts": "^1.0.2",
    "vite": "^8.0.10",
    "vite-plugin-vue-devtools": "^8.0.5",
    "vitepress": "^1.6.4",
    "vitepress-plugin-lightbox": "^1.0.3",
    "vitest": "^2.1.0",
    "vue": "3.5.38",
    "vue-tsc": "^3.1.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp"
    ]
  }
}
