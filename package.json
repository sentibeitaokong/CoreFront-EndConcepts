{
  "name": "corefront-endconcepts",
  "version": "1.0.0",
  "type": "module",
  "lint-staged": {
    "*.{js,jsx,ts,tsx,vue}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{css,less,scss,md,json}": [
      "prettier --write"
    ]
  },
  "packageManager": "pnpm@11.2.2",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "type-check": "turbo run type-check",
    "docs:dev": "turbo run docs:dev --filter=docs",
    "docs:build": "turbo run docs:build --filter=docs",
    "docs:preview": "turbo run docs:preview --filter=docs",
    "docs:clean": "rm -rf docs/.vitepress/.temp docs/.vitepress/cache node_modules/.vite",
    "docs:rebuild": "pnpm run docs:clean && pnpm run docs:build",
    "preview": "vite preview",
    "test": "vitest",
    "prepare": "husky"
  },
  "devDependencies": {
    "@rollup/plugin-alias": "^6.0.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@tsconfig/node24": "^24.0.3",
    "@types/jsdom": "^27.0.0",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^24.10.1",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vitejs/plugin-vue-jsx": "^5.1.2",
    "@vitepress-demo-preview/component": "^2.6.2",
    "@vitepress-demo-preview/plugin": "^1.4.1",
    "@vitest/eslint-plugin": "^1.5.0",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.6.0",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.8.1",
    "autoprefixer": "^10.4.23",
    "cssnano": "^7.1.2",
    "esbuild": "^0.28.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-vue": "~10.5.1",
    "happy-dom": "^20.0.11",
    "husky": "^9.1.7",
    "jiti": "^2.6.1",
    "jsdom": "^24.1.3",
    "lint-staged": "^17.0.0",
    "npm-run-all2": "^8.0.4",
    "postcss": "^8.5.6",
    "postcss-color-mix": "^1.1.0",
    "postcss-each": "^1.1.0",
    "postcss-each-variables": "^0.3.0",
    "postcss-for": "^2.1.1",
    "postcss-nested": "^7.0.2",
    "prettier": "^3.6.2",
    "rollup": "^4.60.1",
    "rollup-plugin-esbuild": "^6.2.1",
    "tslib": "^2.8.1",
    "turbo": "^2.9.16",
    "typescript": "~5.9.0",
    "vite": "^7.2.4",
    "vite-plugin-vue-devtools": "^8.0.5",
    "vitepress": "^1.6.4",
    "vitepress-plugin-lightbox": "^1.0.3",
    "vitest": "^2.1.0",
    "vue-tsc": "^3.1.5"
  },
  "dependencies": {
    "@fancyapps/ui": "^6.1.14",
    "@floating-ui/vue": "^1.1.11",
    "@fortawesome/fontawesome-svg-core": "^7.1.0",
    "@fortawesome/free-brands-svg-icons": "^7.1.0",
    "@fortawesome/free-regular-svg-icons": "^7.1.0",
    "@fortawesome/free-solid-svg-icons": "^7.1.0",
    "@fortawesome/vue-fontawesome": "^3.1.2",
    "async-validator": "^4.2.5",
    "lodash-es": "^4.17.23",
    "viewerjs": "^1.11.7",
    "xb-element": "^1.0.6"
  }
}
