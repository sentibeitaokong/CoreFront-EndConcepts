{
  "extends": "../../tsconfig.app.json",
  "include": [
    ".vitepress/**/*.ts",
    ".vitepress/**/*.mts",
    ".vitepress/**/*.vue",
    "components/**/*.vue",
    "../../packages/xbElement/src/**/*.ts",
    "../../packages/xbElement/src/**/*.tsx",
    "../../packages/xbElement/src/**/*.vue"
  ],
  "exclude": [
    ".vitepress/cache/**",
    ".vitepress/dist/**"
  ],
  "compilerOptions": {
    "baseUrl": ".",
    "types": [
      "node"
    ],
    "paths": {
      "xb-element": [
        "../../packages/xbElement/src/index.ts"
      ],
      "xb-element/dist/es/x-element": [
        "../../packages/xbElement/src/index.ts"
      ],
      "xb-element/dist/types/*": [
        "../../packages/xbElement/src/*"
      ],
      "@/*": [
        "../../packages/xbElement/src/*"
      ]
    },
    "tsBuildInfoFile": "../../node_modules/.tmp/tsconfig.docs.tsbuildinfo"
  }
}
